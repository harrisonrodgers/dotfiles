{
    "diagnostic.messageDelay": 0,
    "diagnostic.errorSign": "->",
    "diagnostic.warningSign": "->",
    "diagnostic.infoSign": "->",
    "diagnostic.hintSign": "->",
    "suggest.enablePreview": true,
    "diagnostic.virtualText": false,
    "diagnostic.virtualTextPrefix": "◾",
    "signature.maxWindowHeight": 15,
    "signature.maxWindowWidth": 120,
    "suggest.maxPreviewWidth": 120,
    "diagnostic.maxWindowWidth": 120,
    "python.jediEnabled": false,
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": [
        "--line-length=120"
    ],
    "coc.preferences.formatOnSaveFiletypes": ["python", "json", "yaml"],
    "python.linting.enabled": true,
    "python.linting.lintOnSave": true,
    "python.linting.mypyEnabled": true,
    "python.linting.mypyArgs": [
        "--ignore-missing-imports",
        "--show-column-numbers"
    ],
    "python.linting.pep8Enabled": false,
    "python.linting.pylamaEnabled": true,
    "python.linting.pylamaArgs": [
        "--max-line-length=120"
    ],
    "python.linting.pylintEnabled": true,
    "python.linting.pylintArgs": [
        "--disable=C0114,C0115,C0116,C0301,C0411,C0412,W1203,C0330,W0611,W0703,R0903",
        "--ignore-patterns=test_*"
    ],
    "python.linting.flake8Enabled": true,
    "python.linting.flake8Args": [
        "--max-line-length=120",
        "--ignore=E203,E501,W503"
    ],
    "python.linting.pydocstyleEnabled": true,
    "python.linting.pydocstyleArgs": [
        "--add-select=D212"
    ],
    "git.addGBlameToBufferVar": true,
    "highlight.colors.enable": true,
    "highlight.document.enable": true,
    "json.format.enable": true,
    "yaml.format.enable": true
}
